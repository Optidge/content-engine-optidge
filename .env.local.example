# ContentEngine — copy to .env.local and fill in values

# Anthropic (required for topic generation)
ANTHROPIC_API_KEY=

# Google OAuth (GSC + Sheets/Drive for content calendars)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase (Beta client profiles + history + feedback)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
